{
  "name": "alumniconnect-portal-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run server --prefix backend",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev": "npm run dev:full"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
